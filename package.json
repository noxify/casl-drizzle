{
  "name": "@noxify/casl-drizzle",
  "version": "0.1.0",
  "description": "Drizzle-ORM adapter for CASL - generate Drizzle where inputs from CASL abilities",
  "keywords": [
    "ability",
    "acl",
    "authorization",
    "casl",
    "drizzle",
    "drizzle-orm",
    "permissions",
    "query-builder",
    "rbac",
    "relational",
    "type-safe",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxify/casl-drizzle"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "ci:publish": "pnpm build && pnpm publish -r --access public --publish-branch main && pnpm changeset tag",
    "ci:version": "pnpm changeset version && pnpm install --no-frozen-lockfile && git add .",
    "cs": "changeset",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix && pnpm format:fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deps:update": "pnpm update -i -L -r"
  },
  "dependencies": {
    "@ucast/core": "2.0.0",
    "@ucast/js": "4.0.1"
  },
  "devDependencies": {
    "@casl/ability": "7.0.0",
    "@changesets/cli": "2.31.0",
    "@electric-sql/pglite": "0.4.6",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.7",
    "dedent": "1.7.2",
    "drizzle-kit": "1.0.0-rc.3",
    "drizzle-orm": "1.0.0-rc.3",
    "json-schema-to-typescript": "15.0.4",
    "node-pty": "1.1.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "tsdown": "0.22.1",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "ultracite": "7.8.0",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@casl/ability": "^7.0.0",
    "drizzle-orm": ">=1.0.0-rc.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.4.0",
  "authors": [
    {
      "name": "Marcus Reinhardt",
      "email": "webstone@gmail.com"
    }
  ]
}
