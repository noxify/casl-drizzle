{
  "name": "@noxify/casl-drizzle",
  "version": "0.3.0",
  "description": "Drizzle-ORM adapter for CASL - generate Drizzle where inputs from CASL abilities",
  "keywords": [
    "ability",
    "acl",
    "authorization",
    "casl",
    "drizzle",
    "drizzle-orm",
    "permissions",
    "query-builder",
    "rbac",
    "relational",
    "type-safe",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noxify/casl-drizzle"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix && pnpm format:fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "tegami": "node scripts/tegami.mts",
    "test": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deps:update": "pnpm update -i -L -r"
  },
  "dependencies": {
    "@ucast/core": "2.0.0",
    "@ucast/js": "4.0.1"
  },
  "devDependencies": {
    "@casl/ability": "7.0.1",
    "@electric-sql/pglite": "0.5.4",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "dedent": "1.7.2",
    "drizzle-kit": "1.0.0-rc.4",
    "drizzle-orm": "1.0.0-rc.4",
    "json-schema-to-typescript": "15.0.4",
    "node-pty": "1.1.0",
    "oxfmt": "0.60.0",
    "oxlint": "1.75.0",
    "tegami": "1.2.6",
    "tsdown": "0.22.13",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "ultracite": "7.9.4",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@casl/ability": "^7.0.1",
    "drizzle-orm": ">=1.0.0-rc.4"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.15.1",
  "authors": [
    {
      "name": "Marcus Reinhardt",
      "email": "webstone@gmail.com"
    }
  ]
}
